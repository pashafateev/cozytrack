{
  "name": "cozytrack",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash ./scripts/check-aws-auth.sh && next dev -p 3001",
    "dev:local": "docker compose up -d && npm run db:push && npm run dev",
    "init:local": "npm run reset:local && npm run dev",
    "reset:local": "bash ./scripts/reset-local.sh",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@livekit/components-react": "^2.6.0",
    "@prisma/client": "^6.0.0",
    "livekit-client": "^2.6.0",
    "livekit-server-sdk": "^2.9.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recordrtc": "^5.6.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/recordrtc": "^5.6.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0"
  }
}
